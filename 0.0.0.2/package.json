{
    "name": "flex-cms",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "npm run migrate:status && vite",
        "build": "vite build",
        "preview": "vite preview",
        "migrate": "php vendor/bin/phinx migrate",
        "rollback": "php vendor/bin/phinx rollback",
        "migrate:create": "php vendor/bin/phinx create",
        "migrate:status": "php vendor/bin/phinx status",
        "seed": "php vendor/bin/phinx seed:run -s UserSeeder"
    },
    "dependencies": {
        "@alpinejs/collapse": "^3.15.12",
        "@fortawesome/fontawesome-free": "^7.2.0",
        "alpinejs": "^3.14.0",
        "axios": "^1.16.1",
        "tailwindcss": "^4.0.0"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.3.0",
        "vite": "^6.0.0"
    }
}
